{
  "manifest_version": 3,
  "name": "なろう読み上げ辞書分離版",
  "version": "1.4",
  "permissions": [
    "tts",
    "storage",
    "contextMenus",
    "activeTab",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TSS設定を開く"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://ncode.syosetu.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dictionary.json"
      ],
      "matches": [
        "https://ncode.syosetu.com/*"
      ]
    }
  ]
}